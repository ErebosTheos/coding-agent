step_6["Add minimal CSS for layout centering and button visibility."]
step_5 --> step_6
step_7["Import http.server and socketserver modules."]
step_6 --> step_7
step_8["Configure the server to listen on port 8080."]
step_7 --> step_8
step_9["Set up the handler to serve files from the current directory."]
step_8 --> step_9
step_10["Add a print statement indicating the server is running at http://localhost:8080."]
step_9 --> step_10
end
