# ═══════════════════════════════════════════════════════════════════════════════
# PERFORMANCE PROFILES — choose one block and copy to .env
# ═══════════════════════════════════════════════════════════════════════════════
#
# FAST profile  — lowest latency, deterministic guards absorb most failures.
#                 Best for batch jobs and projects with known stack patterns.
#
#   CODEGEN_CACHE=1
#   CODEGEN_PATCH_CACHE=1
#   CODEGEN_LIVE_GUARD_MAX_LLM=0      # deterministic-only Tier 2 (no LLM micro-heal)
#   CODEGEN_EXECUTOR_CONCURRENCY=12
#   CODEGEN_EXECUTOR_MAX_BULK_FILES=0  # always wave-based (better for parallel I/O)
#
# BALANCED profile (recommended) — guards on, small LLM heal budget, patch cache active.
#
#   CODEGEN_CACHE=1
#   CODEGEN_PATCH_CACHE=1
#   CODEGEN_LIVE_GUARD_MAX_LLM=5
#   CODEGEN_EXECUTOR_CONCURRENCY=8
#
# STRICT profile — full LLM heal budget, all guards on, patch cache warms fast.
#                  Best for first runs on complex projects.
#
#   CODEGEN_CACHE=1
#   CODEGEN_PATCH_CACHE=1
#   CODEGEN_LIVE_GUARD_MAX_LLM=10
#   CODEGEN_EXECUTOR_CONCURRENCY=6
#
# ═══════════════════════════════════════════════════════════════════════════════

# ---- Global defaults ----
CODEGEN_PROVIDER=gemini
CODEGEN_CACHE=1

# ---- PatchCache (persistent failure → patch store, zero LLM on cache hits) ----
CODEGEN_PATCH_CACHE=1

# ---- LiveGuard Tier 2: max LLM micro-heals per run (0 = deterministic only) ----
CODEGEN_LIVE_GUARD_MAX_LLM=10

# ---- Timeouts (prevents "stuck" runs) ----
CODEGEN_LLM_TIMEOUT=180
CODEGEN_LLM_STREAM_IDLE_TIMEOUT=300
CODEGEN_LLM_STREAM_MAX_TIMEOUT=600

# ---- Executor tuning ----
CODEGEN_EXECUTOR_CONCURRENCY=10

# ---- Role routing (recommended: fast + stable) ----
CODEGEN_PLANNER_PROVIDER=claude
CODEGEN_ARCHITECT_PROVIDER=claude_code
CODEGEN_EXECUTOR_PROVIDER=gemini
CODEGEN_TESTER_PROVIDER=gemini
CODEGEN_HEALER_PROVIDER=codex
CODEGEN_QA_AUDITOR_PROVIDER=gemini

# ---- Multi-model executor tiers (within-role specialisation) ----
# "simple" tier: config/schema/init files (no deps) → use a cheaper/faster model
# "complex" tier: auth/database/entrypoint files (≥5 deps) → use a smarter model
# If unset, the standard executor client is used for all files.
#
# Example (Anthropic):
#   CODEGEN_FAST_PROVIDER=anthropic
#   CODEGEN_FAST_MODEL=claude-haiku-4-5-20251001
#   CODEGEN_COMPLEX_PROVIDER=anthropic
#   CODEGEN_COMPLEX_MODEL=claude-opus-4-6
#
# CODEGEN_FAST_PROVIDER=
# CODEGEN_FAST_MODEL=
# CODEGEN_COMPLEX_PROVIDER=
# CODEGEN_COMPLEX_MODEL=

# ---- Optional fallbacks ----
CODEGEN_PLANNER_FALLBACK_PROVIDER=gemini
CODEGEN_ARCHITECT_FALLBACK_PROVIDER=gemini
CODEGEN_EXECUTOR_FALLBACK_PROVIDER=claude_code
CODEGEN_TESTER_FALLBACK_PROVIDER=codex
CODEGEN_HEALER_FALLBACK_PROVIDER=claude_code
CODEGEN_QA_AUDITOR_FALLBACK_PROVIDER=claude_code

# ---- API credentials ----
# ANTHROPIC_API_KEY=your_key_here
