# ─────────────────────────────────────────────────────────────
# Codegen Agent — Provider Configuration
# Copy this file to .env and set your provider.
# ─────────────────────────────────────────────────────────────

# ── Provider options ──────────────────────────────────────────
#
#  claude_code   → uses the local `claude` CLI binary (Claude Code)
#                  No API key needed — uses your existing Claude Code session.
#                  This is the recommended default.
#
#  claude        → Anthropic HTTP API (requires ANTHROPIC_API_KEY)
#  gemini        → Gemini CLI binary (requires GEMINI_API_KEY or gcloud auth)
#  openai/codex  → OpenAI API (requires OPENAI_API_KEY)
#
CODEGEN_PROVIDER=claude_code

# ── Model override (optional) ─────────────────────────────────
# CODEGEN_MODEL=claude-sonnet-4-6            # default
# CODEGEN_MODEL=claude-haiku-4-5-20251001    # fastest/cheapest
# CODEGEN_MODEL=claude-opus-4-6              # most capable
# CODEGEN_MODEL=gpt-4o                       # OpenAI default
# CODEGEN_MODEL=gpt-4o-mini                  # OpenAI cheap

# ── API keys (only needed for non-CLI providers) ──────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ── Per-role overrides (optional) ────────────────────────────
# Run cheap/fast model for simple roles, powerful for complex ones.
#
# CODEGEN_PLANNER_PROVIDER=claude_code
# CODEGEN_PLANNER_MODEL=claude-haiku-4-5-20251001
#
# CODEGEN_ARCHITECT_PROVIDER=claude_code
# CODEGEN_ARCHITECT_MODEL=claude-sonnet-4-6
#
# CODEGEN_EXECUTOR_PROVIDER=claude_code
# CODEGEN_EXECUTOR_MODEL=claude-sonnet-4-6
#
# CODEGEN_TESTER_PROVIDER=claude_code
# CODEGEN_TESTER_MODEL=claude-haiku-4-5-20251001
#
# CODEGEN_HEALER_PROVIDER=claude_code
# CODEGEN_HEALER_MODEL=claude-sonnet-4-6
#
# CODEGEN_QA_AUDITOR_PROVIDER=claude_code
# CODEGEN_QA_AUDITOR_MODEL=claude-haiku-4-5-20251001
